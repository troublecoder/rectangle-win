{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rectangle Win",
  "version": "0.1.0",
  "identifier": "com.troublecoder.rectangle-win",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Rectangle Win",
        "label": "main",
        "width": 900,
        "height": 640,
        "minWidth": 720,
        "minHeight": 500,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "RWRTY0IyxqHc6Tn1xzJumqdOJw7SEeA8+jIp+tr2Fxu1VP1PIVIAABAAAAAAAAAAAAIAAAAA6oivl5J1p1XJPnjOJDHp706zRWGT+UsLR5fvfWMA+AS4hIpxgtezlXZzARlmnmI95/2AlYMrZf6YsGBCY3PHsHp7gqbqs4PmS/j/OaF0ZjNgsGYjGkh5DLs290sLBC9C0laNZGGE9po=",
      "endpoints": [
        "https://github.com/troublecoder/rectangle-win/releases/latest/download/latest.json"
      ]
    }
  }
}
